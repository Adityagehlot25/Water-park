# Frontend API Configuration Examples

# Development
# VITE_API_BASE_URL=http://localhost:5000

# Production - for server deployments (replace with your actual domain)
# VITE_API_BASE_URL=https://api.yourdomain.com

# Production - for same-origin deployments (backend on same server)
# VITE_API_BASE_URL=/api

# Default behavior: auto-detects localhost or uses same origin
